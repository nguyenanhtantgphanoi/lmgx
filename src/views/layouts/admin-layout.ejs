<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/admin-layout.css" />
  <% if (Array.isArray(styles)) { %>
    <% styles.forEach(function(file) { %>
      <link rel="stylesheet" href="/<%= file %>" />
    <% }); %>
  <% } %>
</head>
<body>
  <div class="admin-shell">
    <aside class="admin-sidebar">
      <div class="brand">
        <p class="brand-title">Parish Admin</p>
        <p class="brand-subtitle">Control Center</p>
      </div>
      <nav class="admin-nav" aria-label="Admin navigation">
        <% navItems.forEach(function(item) { %>
          <a
            class="nav-link <%= item.path === activePath ? 'is-active' : '' %>"
            href="<%= item.path %>"
            data-nav-path="<%= item.path %>"
          >
            <span><%= item.label %></span>
            <% if (item.path === '/deleted-priest-manager') { %>
              <span id="deletedProfilesBadge" class="nav-badge" hidden>0</span>
            <% } %>
          </a>
        <% }); %>
      </nav>
      <div class="sidebar-footer">
        <form method="POST" action="/logout">
          <button type="submit" class="btn-logout">Sign Out</button>
        </form>
      </div>
    </aside>

    <main class="admin-main">
      <header class="topbar">
        <h1><%= heading %></h1>
        <p><%= subheading %></p>
      </header>

      <section class="content">
        <%- include(pagePartial, pageData || {}) %>
      </section>
    </main>
  </div>

  <% if (Array.isArray(scripts)) { %>
    <% scripts.forEach(function(file) { %>
      <script src="/<%= file %>" defer></script>
    <% }); %>
  <% } %>
  <script>
    window.addEventListener('DOMContentLoaded', async function () {
      const badge = document.getElementById('deletedProfilesBadge');
      if (!badge) return;

      try {
        const response = await fetch('/api/priests/deleted');
        if (!response.ok) return;

        const priests = await response.json();
        const count = Array.isArray(priests) ? priests.length : 0;

        if (count > 0) {
          badge.textContent = String(count);
          badge.hidden = false;
        } else {
          badge.hidden = true;
        }
      } catch (_error) {
        badge.hidden = true;
      }
    });
  </script>
</body>
</html>
