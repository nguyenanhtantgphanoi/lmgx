<section class="panel">
  <div class="panel-head">
    <h2>Deleted Priest Profiles</h2>
    <button id="refreshDeletedPriestsBtn" type="button">Refresh</button>
  </div>
  <p id="deletedPriestMessage" class="priest-message" aria-live="polite"></p>
  <div class="table-wrap">
    <table class="priests-table">
      <thead>
        <tr>
          <th>Họ và tên</th>
          <th>Deleted By</th>
          <th>Deleted At</th>
          <th>Thao tác</th>
        </tr>
      </thead>
      <tbody id="deletedPriestsBody"></tbody>
    </table>
  </div>
</section>

<template id="deletedPriestRowTemplate">
  <tr>
    <td class="priest-full-name"></td>
    <td class="priest-deleted-by"></td>
    <td class="priest-deleted-at"></td>
    <td class="actions">
      <button class="btn-link" data-action="restore" type="button">Restore</button>
      <button class="btn-delete" data-action="permanent-delete" type="button">Delete Permanently</button>
    </td>
  </tr>
</template>

<div id="deletedIdentityVerifyModal" class="reauth-modal" aria-hidden="true">
  <div class="reauth-modal-card" role="dialog" aria-modal="true" aria-labelledby="deletedIdentityModalTitle">
    <h3 id="deletedIdentityModalTitle">Xác thực để xóa vĩnh viễn</h3>
    <p id="deletedIdentityModalHint">Vui lòng nhập tài khoản quản trị để xác nhận.</p>

    <form id="deletedIdentityVerifyForm" class="reauth-form">
      <label>
        Username
        <input id="deletedIdentityVerifyUsername" name="username" type="text" autocomplete="username" required />
      </label>
      <label>
        Password
        <input id="deletedIdentityVerifyPassword" name="password" type="password" autocomplete="current-password" required />
      </label>
      <p id="deletedIdentityVerifyError" class="reauth-error" aria-live="polite"></p>

      <div class="reauth-actions">
        <button type="button" id="deletedIdentityVerifyCancel" class="btn-reauth-cancel">Hủy</button>
        <button type="submit" class="btn-reauth-confirm">Xác nhận xóa vĩnh viễn</button>
      </div>
    </form>
  </div>
</div>
