<section id="priestProfileRoot" class="panel" data-priest-id="<%= priestId %>">
  <div class="panel-head">
    <h2>Hồ sơ Linh mục</h2>
    <p id="profileMessage" class="profile-message" aria-live="polite"></p>
  </div>

  <nav class="profile-tabs" id="profileTabs" role="tablist">
    <button type="button" class="tab-btn active" data-tab="personal">Cá nhân</button>
    <button type="button" class="tab-btn" data-tab="family">Gia đình</button>
    <button type="button" class="tab-btn" data-tab="education">Học vấn</button>
    <button type="button" class="tab-btn" data-tab="sacraments">Bí tích</button>
    <button type="button" class="tab-btn" data-tab="ordination">Truyền chức</button>
    <button type="button" class="tab-btn" data-tab="transfer">Chuyển giáo phận</button>
    <button type="button" class="tab-btn" data-tab="ministry">Sứ vụ</button>
    <button type="button" class="tab-btn" data-tab="notes1">Ghi chú 1</button>
    <button type="button" class="tab-btn" data-tab="notes2">Ghi chú 2</button>
    <button type="button" class="tab-btn" data-tab="files">Tệp hồ sơ</button>
  </nav>

  <form id="priestProfileForm">

    <!-- TAB: Cá nhân -->
    <fieldset class="tab-panel active" id="tab-personal">
      <legend>Thông tin cá nhân</legend>
      <div class="form-grid">
        <label>
          Tên thánh
          <input name="saintName" type="text" />
        </label>
        <label>
          Họ và tên <em>(bắt buộc)</em>
          <input name="fullName" type="text" required />
        </label>
        <div class="col-span-2 avatar-upload">
          <div class="avatar-preview-wrap">
            <img id="avatarPreview" class="avatar-preview" alt="Priest avatar" />
          </div>
          <label class="avatar-input">
            Ảnh đại diện
            <input id="avatarFileInput" name="avatarFile" type="file" accept="image/*" />
          </label>
        </div>
        <div class="col-span-2 avatar-library-wrap">
          <div class="array-section-head">
            <h3>Thư viện ảnh đại diện đã tải lên</h3>
          </div>
          <div id="avatarLibrary" class="avatar-library"></div>
        </div>
        <label>
          Sinh ngày
          <input name="dateOfBirth" type="date" />
        </label>
        <label>
          Nơi sinh
          <input name="placeOfBirth" type="text" />
        </label>
        <label>
          Giáo họ
          <input name="homeCommunity" type="text" />
        </label>
        <label>
          Giáo xứ
          <input name="homeParish" type="text" />
        </label>
        <label>
          Giáo phận
          <input name="diocese" type="text" />
        </label>
        <label>
          Số điện thoại
          <input name="phone" type="tel" />
        </label>
        <label>
          Email
          <input name="email" type="email" />
        </label>
        <label class="col-span-2">
          Hộ khẩu thường trú
          <input name="permanentAddress" type="text" />
        </label>
        <label>
          Tên nơi tạm trú
          <input name="temporaryResidenceName" type="text" />
        </label>
        <label>
          Địa chỉ tạm trú
          <input name="temporaryResidenceAddress" type="text" />
        </label>
        <div class="col-span-2 id-group">
          <div class="id-col">
            <label>
              Số CCCD
              <input name="nationalId" type="text" />
            </label>
            <label>
              Ngày cấp CCCD
              <input name="nationalIdIssuedDate" type="date" />
            </label>
            <label>
              Nơi cấp CCCD
              <input name="nationalIdIssuedPlace" type="text" />
            </label>
          </div>
          <div class="id-col">
            <label>
              Số Passport
              <input name="passport" type="text" />
            </label>
            <label>
              Ngày cấp Passport
              <input name="passportIssuedDate" type="date" />
            </label>
            <label>
              Nơi cấp Passport
              <input name="passportIssuedPlace" type="text" />
            </label>
          </div>
        </div>
        <label class="col-span-2">
          Số thẻ Bảo hiểm y tế
          <input name="healthInsuranceId" type="text" />
        </label>
        <label>
          Tình trạng
          <select name="status">
            <option value="active">Đang hoạt động</option>
            <option value="inactive">Không hoạt động</option>
            <option value="retired">Đã nghỉ hưu</option>
          </select>
        </label>
      </div>
    </fieldset>

    <!-- TAB: Gia đình -->
    <fieldset class="tab-panel" id="tab-family">
      <legend>Thông tin về Gia đình</legend>
      <div class="form-grid">
        <label>
          Tên thánh, Họ tên cha
          <input name="fatherName" type="text" />
        </label>
        <label>
          Tên thánh, Họ tên mẹ
          <input name="motherName" type="text" />
        </label>
        <label class="col-span-2">
          Địa chỉ gia đình
          <input name="familyAddress" type="text" />
        </label>
        <label>
          Thuộc giáo họ
          <input name="familyCommunity" type="text" />
        </label>
        <label>
          Thuộc giáo xứ
          <input name="familyParish" type="text" />
        </label>
      </div>
      <div class="array-section">
        <div class="array-section-head">
          <h3>Anh chị em trong gia đình</h3>
          <button type="button" id="addSiblingBtn" class="btn-add">+ Thêm</button>
        </div>
        <table class="array-table">
          <thead>
            <tr>
              <th>Tên thánh, Họ tên</th>
              <th>Giới tính</th>
              <th>Năm sinh</th>
              <th>Năm mất</th>
              <th>Nghề nghiệp</th>
              <th></th>
            </tr>
          </thead>
          <tbody id="siblingsBody"></tbody>
        </table>
      </div>
    </fieldset>

    <!-- TAB: Học vấn -->
    <fieldset class="tab-panel" id="tab-education">
      <legend>Thông tin Ơn gọi / Học vấn</legend>
      <div class="array-section">
        <div class="array-section-head">
          <h3>Các trường Đại học / Cao đẳng / Đại Chủng viện đã học</h3>
          <button type="button" id="addSchoolBtn" class="btn-add">+ Thêm trường</button>
        </div>
        <div id="schoolsList"></div>
      </div>
    </fieldset>

    <!-- TAB: Bí tích -->
    <fieldset class="tab-panel" id="tab-sacraments">
      <legend>Thông tin Bí tích</legend>

      <div class="sacrament-section">
        <h3>Bí tích Rửa tội</h3>
        <div class="form-grid">
          <label>
            Ngày Rửa tội
            <input name="baptism.date" type="date" />
          </label>
          <label class="col-span-2">
            Nơi rửa tội (Tên nhà thờ, địa chỉ)
            <input name="baptism.place" type="text" />
          </label>
          <label>
            Người rửa tội
            <input name="baptism.minister" type="text" />
          </label>
          <label>
            Người đỡ đầu
            <input name="baptism.godparent" type="text" />
          </label>
        </div>
      </div>

      <div class="sacrament-section">
        <h3>Bí tích Thêm sức</h3>
        <div class="form-grid">
          <label>
            Ngày Thêm sức
            <input name="confirmation.date" type="date" />
          </label>
          <label class="col-span-2">
            Nơi Thêm sức (Tên nhà thờ, địa chỉ)
            <input name="confirmation.place" type="text" />
          </label>
          <label>
            Người ban bí tích Thêm sức
            <input name="confirmation.minister" type="text" />
          </label>
          <label>
            Người đỡ đầu
            <input name="confirmation.godparent" type="text" />
          </label>
        </div>
      </div>
    </fieldset>

    <!-- TAB: Truyền chức -->
    <fieldset class="tab-panel" id="tab-ordination">
      <legend>Thông tin Truyền chức</legend>

      <div class="sacrament-section">
        <h3>Truyền chức Phó tế</h3>
        <div class="form-grid">
          <label class="col-span-2">
            Nơi chịu chức Phó tế (Tên nhà thờ, địa chỉ)
            <input name="diaconate.place" type="text" />
          </label>
          <label>
            Ngày chịu chức Phó tế
            <input name="diaconate.date" type="date" />
          </label>
          <label>
            Do Đức Giám mục
            <input name="diaconate.bishop" type="text" />
          </label>
        </div>
      </div>

      <div class="sacrament-section">
        <h3>Truyền chức Linh mục</h3>
        <div class="form-grid">
          <label class="col-span-2">
            Nơi chịu chức Linh mục (Tên nhà thờ, địa chỉ)
            <input name="priesthood.place" type="text" />
          </label>
          <label>
            Ngày chịu chức Linh mục
            <input name="priesthood.date" type="date" />
          </label>
          <label>
            Do Đức Giám mục
            <input name="priesthood.bishop" type="text" />
          </label>
        </div>
      </div>
    </fieldset>

    <!-- TAB: Chuyển giáo phận -->
    <fieldset class="tab-panel" id="tab-transfer">
      <legend>Thông tin chuyển Giáo phận</legend>
      <div class="form-grid">
        <label class="col-span-2">
          Linh mục gốc Giáo phận / Dòng tu
          <input name="originalDiocese" type="text" />
        </label>
        <label>
          Gia nhập TGP Hà Nội từ ngày
          <input name="joinedDioceseDate" type="date" />
        </label>
      </div>
    </fieldset>

    <!-- TAB: Sứ vụ -->
    <fieldset class="tab-panel" id="tab-ministry">
      <legend>Thông tin Giáo vụ — Lịch sử Sứ vụ</legend>
      <div class="array-section">
        <div class="array-section-head">
          <h3>Danh sách sứ vụ</h3>
          <button type="button" id="addMissionBtn" class="btn-add">+ Thêm sứ vụ</button>
        </div>
        <div id="missionsList"></div>
      </div>
    </fieldset>

    <!-- TAB: Ghi chú 1 -->
    <fieldset class="tab-panel" id="tab-notes1">
      <legend>Thông tin Ghi chú 1</legend>
      <div class="array-section">
        <div class="array-section-head">
          <h3>Danh sách ghi chú</h3>
        </div>
        <ul id="profileNotesList" class="profile-notes-list"></ul>
        <p id="profileNotesEmpty" class="profile-notes-empty">Chưa có ghi chú nào.</p>
      </div>
      <div class="notes-add-row">
        <label class="col-span-2">
          Thêm ghi chú mới
          <textarea id="newProfileNoteInput" rows="3" placeholder="Nhập nội dung ghi chú..."></textarea>
        </label>
        <button type="button" id="addProfileNoteBtn" class="btn-add">+ Thêm ghi chú</button>
      </div>
      <textarea name="notes" hidden></textarea>
    </fieldset>

    <!-- TAB: Ghi chú 2 -->
    <fieldset class="tab-panel" id="tab-notes2">
      <legend>Ghi chú 2 (Phần dành riêng cho Tòa Giám mục)</legend>
      <div class="form-grid">
        <label>
          Qua đời ngày
          <input name="dateOfDeath" type="date" />
        </label>
        <label>
          Nơi qua đời
          <input name="placeOfDeath" type="text" />
        </label>
        <label>
          Ngày an táng
          <input name="burialDate" type="date" />
        </label>
        <label>
          Nơi an táng
          <input name="placeOfBurial" type="text" />
        </label>
      </div>
    </fieldset>

    <!-- TAB: Tệp hồ sơ -->
    <fieldset class="tab-panel" id="tab-files">
      <legend>Tệp thuộc hồ sơ linh mục</legend>
      <div class="array-section">
        <div class="array-section-head">
          <h3>Danh sách tệp trong thư mục hồ sơ</h3>
          <button type="button" id="refreshProfileFilesBtn" class="btn-add">Làm mới</button>
        </div>
        <div id="profileFilesList" class="profile-files-list"></div>
      </div>
    </fieldset>

    <div class="profile-actions">
      <button type="submit">Lưu thay đổi</button>
      <button type="button" id="deletePriestBtn" class="btn-delete">Xóa hồ sơ</button>
    </div>
  </form>

  <div id="editNoteModal" class="identity-modal" aria-hidden="true">
    <div class="identity-modal-card" role="dialog" aria-modal="true" aria-labelledby="editNoteModalTitle">
      <h3 id="editNoteModalTitle">Sửa ghi chú</h3>
      <form id="editNoteForm" class="identity-form">
        <label>
          Nội dung ghi chú
          <textarea id="editNoteTextarea" rows="5" required></textarea>
        </label>
        <div class="identity-actions">
          <button type="button" id="editNoteCancel" class="btn-cancel">Hủy</button>
          <button type="submit" class="btn-verify">Lưu</button>
        </div>
      </form>
    </div>
  </div>

  <div id="identityVerifyModal" class="identity-modal" aria-hidden="true">
    <div class="identity-modal-card" role="dialog" aria-modal="true" aria-labelledby="identityModalTitle">
      <h3 id="identityModalTitle">Xác thực để xóa hồ sơ</h3>
      <p>Vui lòng nhập tài khoản quản trị để xác nhận hành động này.</p>

      <form id="identityVerifyForm" class="identity-form">
        <label>
          Username
          <input id="identityVerifyUsername" name="username" type="text" autocomplete="username" required />
        </label>
        <label>
          Password
          <input id="identityVerifyPassword" name="password" type="password" autocomplete="current-password" required />
        </label>
        <p id="identityVerifyError" class="identity-error" aria-live="polite"></p>

        <div class="identity-actions">
          <button type="button" id="identityVerifyCancel" class="btn-cancel">Hủy</button>
          <button type="submit" class="btn-verify">Xác nhận</button>
        </div>
      </form>
    </div>
  </div>

  <div id="unsavedChangesModal" class="identity-modal" aria-hidden="true">
    <div class="identity-modal-card" role="dialog" aria-modal="true" aria-labelledby="unsavedChangesTitle">
      <h3 id="unsavedChangesTitle">Thay đổi chưa được lưu</h3>
      <p>Bạn có thay đổi chưa lưu. Bạn muốn làm gì?</p>
      <div class="identity-actions unsaved-actions">
        <button type="button" id="unsavedLeaveBtn" class="btn-cancel">Rời không lưu</button>
        <button type="button" id="unsavedSaveBtn" class="btn-verify">Lưu và rời</button>
        <button type="button" id="unsavedCancelBtn" class="btn-add">Hủy</button>
      </div>
    </div>
  </div>
</section>
